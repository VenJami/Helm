{
  "name": "helm-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "description": "Helm — multi-session Claude Code orchestrator (backend: PTY + WebSocket)",
  "main": "index.mjs",
  "scripts": {
    "dev": "node --watch index.mjs",
    "start": "node index.mjs",
    "test": "node --test test/smoke.mjs",
    "e2e": "node test/e2e-real.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"*.mjs\" \"src/**/*.mjs\" \"test/**/*.mjs\"",
    "format:check": "prettier --check \"*.mjs\" \"src/**/*.mjs\" \"test/**/*.mjs\""
  },
  "dependencies": {
    "express": "^4.21.2",
    "node-pty": "1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.25",
    "@types/node": "^22.20.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
